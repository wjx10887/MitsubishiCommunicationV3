<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="appSettings" type="System.Configuration.AppSettingsSection, System.Configuration, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" requirePermission="false" />
  </configSections>
  <appSettings>
    <!-- 应用程序设置 -->
    <add key="AppVersion" value="3.0.0" />
    <add key="DefaultIpAddress" value="192.168.1.100" />
    <add key="DefaultPort" value="502" />
    <add key="DefaultTimeout" value="3000" />
    <add key="LogFilePath" value="Logs" />
    <!-- 日志设置 -->
    <add key="LogLevel" value="Info" />
    <!-- PLC默认连接参数 -->
    <add key="DefaultPlcSeries" value="Q" />
    <add key="DefaultStationNumber" value="0" />
    <add key="DefaultNetworkNumber" value="0" />
    <!-- 监控模式设置 -->
    <add key="DefaultMonitorInterval" value="1000" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>